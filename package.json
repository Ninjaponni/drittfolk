{
  "name": "drittfolk",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && node --watch --env-file=.env server.js",
    "build": "cd client && npm run build",
    "start": "cd server && node --env-file=.env server.js",
    "seed": "cd server && node seed.js",
    "convert-assets": "bash scripts/convert-assets.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "fbx2gltf": "^0.9.7-p1"
  }
}
